# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# Bundled embedding-model weights (~90MB each), one subdir per model under
# models/<name>/. Fetched out-of-band via ./fetch-model.sh; not tracked in git.
/models

# Prebuilt PDFium dynamic library, fetched per-target by build.rs and bundled as
# a Tauri resource. Platform-specific binary; not tracked in git.
/libpdfium
